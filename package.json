{
    "name": "twitch-chat-overlay",
    "version": "1.0.0",
    "description": "Overlay de Chat da Twitch",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder --win --dir",
        "dist": "electron-builder --win",
        "build-exe": "npx electron-packager . \"Twitch Chat Overlay\" --platform=win32 --arch=x64 --out=. --overwrite"
    },
    "build": {
        "appId": "com.seuprojeto.twitchoverlay",
        "productName": "Twitch Chat Overlay",
        "win": {
            "target": "nsis"
        }
    },
    "dependencies": {
        "tmi.js": "^1.8.5"
    },
    "devDependencies": {
        "electron": "^28.2.3",
        "electron-builder": "^26.8.1",
        "electron-packager": "^17.1.2"
    }
}